PORT=5000

# Preferred server-side Supabase config
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Browser auth config for the Vite client
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=

# Optional server fallback if you are only using public access with RLS policies
SUPABASE_ANON_KEY=

# The server and client also accept these Expo-style variables as fallback inputs:
# EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: in development this defaults to true, in production it defaults to false.
ALLOW_MEMORY_FALLBACK=true

# Comma-separated origins for CORS (for production lock this down to your exact frontend URL(s))
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
APP_BASE_URL=http://localhost:5000

# API rate limiting (stricter defaults are applied in production when unset)
# API_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX=120

# Optional key required to access /api/metrics in production
# METRICS_API_KEY=replace-with-strong-random-value

# HTTP logging controls
# In development, request logs default to "errors + slow requests only".
# Set true to log every API request.
# LOG_ALL_HTTP_REQUESTS=false
# Mark requests as slow when latency is above this threshold.
# LOG_SLOW_REQUEST_MS=1000
# Include user-agent string in request logs.
# LOG_INCLUDE_HTTP_USER_AGENT=false

# Supabase Storage buckets used by signed upload endpoints
LISTING_IMAGES_BUCKET=listing-images
CONTRACT_DOCUMENTS_BUCKET=contract-documents
