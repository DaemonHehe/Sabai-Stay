PORT=5000
ADMIN_API_KEY=

# Preferred server-side Supabase config
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Browser auth config for the Vite client
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=

# Optional server fallback if you are only using public access with RLS policies
SUPABASE_ANON_KEY=

# The server and client also accept these Expo-style variables as fallback inputs:
# EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: in development this defaults to true, in production it defaults to false.
ALLOW_MEMORY_FALLBACK=true
